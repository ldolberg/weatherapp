# Required for /api/weather persistence and history (Supabase → Transaction pooler, port 6543).
# Project Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Vercel Cron: same value in Vercel env; request must send Authorization: Bearer <CRON_SECRET>
CRON_SECRET="use-a-long-random-string"

# Optional — only for server.ts (local / Docker), not Vercel serverless
# WEATHER_CRON_ENABLED="true"
# WEATHER_CRON="*/5 * * * *"

# Optional — injected into the client bundle by Vite if present (see vite.config.ts)
# GEMINI_API_KEY=
